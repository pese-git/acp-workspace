# CodeLab Configuration
# =====================
# Скопируйте в .env и заполните нужные значения

# LLM Provider Configuration
# --------------------------
# Тип провайдера: openai или mock
CODELAB_LLM_PROVIDER=mock

# OpenAI API Key (required for OpenAI provider)
OPENAI_API_KEY=sk-your-key-here

# Anthropic API Key (optional)
ANTHROPIC_API_KEY=your-key-here

# Base URL для LLM провайдера (опционально, для совместимых сервисов)
# CODELAB_LLM_BASE_URL=https://api.openai.com/v1

# Модель LLM
CODELAB_LLM_MODEL=gpt-4o

# Temperature для генерации (0.0-1.0, по умолчанию 0.7)
CODELAB_LLM_TEMPERATURE=0.7

# Максимальное количество токенов в ответе (по умолчанию 8192)
CODELAB_LLM_MAX_TOKENS=8192

# Server Configuration
# --------------------
# Default server port
CODELAB_PORT=8765

# Default server host
CODELAB_HOST=127.0.0.1

# Home directory (default: ~/.codelab)
# CODELAB_HOME=/path/to/home

# Logging Configuration
# ---------------------
# Log level: DEBUG, INFO, WARNING, ERROR
CODELAB_LOG_LEVEL=INFO
