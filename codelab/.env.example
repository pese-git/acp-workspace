# CodeLab Configuration
# =====================

# LLM Provider Configuration
# --------------------------
# LLM provider: openai, anthropic, mock
CODELAB_LLM_PROVIDER=openai

# OpenAI API Key
CODELAB_OPENAI_API_KEY=sk-your-key-here

# Anthropic API Key
CODELAB_ANTHROPIC_API_KEY=your-key-here

# Server Configuration
# --------------------
# Server port (default: 8765)
CODELAB_PORT=8765

# Server host (default: 127.0.0.1)
CODELAB_HOST=127.0.0.1

# Home directory (default: ~/.codelab)
CODELAB_HOME=~/.codelab

# Logging Configuration
# ---------------------
# Log level: DEBUG, INFO, WARNING, ERROR
CODELAB_LOG_LEVEL=INFO
