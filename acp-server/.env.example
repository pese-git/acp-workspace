# Пример конфигурационного файла .env для ACP сервера
# Скопируйте в .env и заполните нужные значения

# === LLM Провайдер ===
# Тип провайдера: openai или mock
ACP_LLM_PROVIDER=mock

# API ключ для OpenAI (требуется если provider=openai)
ACP_LLM_API_KEY=sk-your-api-key-here

# Base URL для LLM провайдера (опционально, для совместимых сервисов)
# ACP_LLM_BASE_URL=https://api.openai.com/v1

# Модель LLM
ACP_LLM_MODEL=gpt-4o

# Temperature для генерации (0.0-1.0, по умолчанию 0.7)
ACP_LLM_TEMPERATURE=0.7

# Максимальное количество токенов в ответе (по умолчанию 8192)
ACP_LLM_MAX_TOKENS=8192

# === Агент ===
# Системный промпт для агента
ACP_SYSTEM_PROMPT=Ты помощник, который помогает пользователю выполнять различные задачи. Используй доступные инструменты для решения задач.
